{
  "name": "trello-api",
  "description": "Invoke any Trello REST API endpoint with auto-approved wrapper scripts, powered by the official OpenAPI spec with jq-based lookup",
  "version": "2.1.2",
  "author": { "name": "DarkbyteAT" },
  "repository": "https://github.com/DarkbyteAT/trello-api-skill",
  "license": "MIT",
  "keywords": ["trello", "api", "rest", "openapi", "curl"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/approve-trello.sh"
          }
        ]
      }
    ]
  }
}
